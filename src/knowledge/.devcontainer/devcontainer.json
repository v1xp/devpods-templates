{
  "name": "knowledge-pod",
  "image": "ghcr.io/v1xp-org/knowledge-pod:latest",
  "containerEnv": {
    "GPG_TTY": "/dev/pts/0",
    "TERM": "xterm-256color"
  },
  "mounts": [
    "source=${localEnv:HOME}/.devpod-keys,target=/tmp/devpod-keys,readonly,type=bind,consistency=cached",
    "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"
  ],
  "postStartCommand": "bash .devcontainer/setup.sh",
  "remoteUser": "vscode"
}
